.main-content {
    width: 50%;
    margin: 50px auto;
    background: #fff;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    border-radius: 8px;

    &__form {
        padding: 32px;
        &--error{
          color: red;
          text-align: center;
        }
        &--message {
          color: $darkGrey;
          text-align: center;
        }
        hr {
            border: 1px solid #f1f1f1;
            margin-bottom: 25px;
        }

        input[type=text], input[type=email], input[type=password] {
            width: 100%;
            padding: 15px;
            margin: 10px 0 20px 0;
            display: inline-block;
            border: 1px solid #ccc;
            border-radius: 4px;
            background: #f9f9f9;
            box-sizing: border-box;
        }

        input[type=text]:focus, input[type=password]:focus {
            background-color: #e9e9e9;
            outline: none;
            border-color: rgb(89, 81, 201);
        }
    }
  &__footer--remember {
    display: grid;
    grid-template-columns: 80% 20%;
    gap: 1rem;
    .forgot-password {
      color: rgb(89, 81, 201);
      text-decoration: none;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 500;
      &:hover {
        text-decoration: none;
        color: rgb(63, 63, 180);
      }
    }
  }

    &__heading {
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        font-weight: bold;
        color: $darkGrey;
        font-size: 36px;
        text-align: center;
        margin-bottom: 24px;
    }

    &__paragraph {
        color: #666;
        text-align: left;
        margin-bottom: 16px;
        &--heading {
            text-align: center;
            font-size: 18px;
        }
    }

    .registerbtn {
        background-color: rgb(89, 81, 201);
        color: $backgroundinput-color;
        padding: 16px 20px;
        margin: 16px 0;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        width: 100%;
        opacity: 0.9;
        font-size: 16px;
    }

    .registerbtn:hover {
        opacity: 1;
    }

    a {
        color: dodgerblue;
    }

    .main-content__footer {
      text-align: center;
      margin-top: 16px;
  
      &--paragraph {
          display: inline; 
          margin-right: 4px; 
      }
  
      &--link {
          display: inline;  
          text-decoration: none;
          color: rgb(89, 81, 201);
          font-weight: 600;
          &:hover {
              text-decoration: underline;
          }
      }
  }
    
  }
  
@media (max-width: 1024px) {
  .main-content {
    &__footer--remember {
      grid-template-columns: 1fr 1fr;
    }
  }
  }