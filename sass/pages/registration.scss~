 @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap");
 @import "../style.scss";

$primary-color: #2c3e50;
$background-color: #93e4c1;
$nav-color: #f6f8fa;
$hover-color: #f1f1f1;
$backgroundinput-color: #ffffff;
$lightGrey: #999;
$grey: #444;
$darkGrey: #333;
$black: #000;
$footer-color: #04AA6D;
$font: "Poppins", sans-serif;
$size: 1rem;

body {
    font-family: $font;
    background-color: $backgroundinput-color;
    color: $primary-color;
    margin: 0;
    padding: 0;
    font-size: $size;
  }
  .header {
    width: 100%;
    height: 15vh;
    display: flex;
  }
.nav {
  width: 190%;
  height: 15vh;
  background-color: $nav-color;
  display: grid;
  grid-template-columns: 30% 70%;
  position: fixed;
  z-index: 9999;
  transition: all 0.3s;
  border-bottom: 0.5px solid rgb(12, 11, 11);

  &__brand {
    padding-left: 40px;
  }

  &__logo {
    background-image: url(../img/img1.png);
    background-size: contain;
    background-position: center;
    width: 150px;
    height: 150px;
    margin-left: 10px;
    cursor: pointer;
    border: 0px solid black;
    border-radius: 50%;
    overflow: hidden;
    a{
      display: flex;
      width: 100%;
      height:100%;
      text-decoration: none;
    }
  }

  &__menu {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-left: 100px;

    &-list {
      display: flex;
      align-items: center;
      list-style-type: none;
    }

    &-item {
      padding: 5px;
      margin-right: 50px;

      a {
        color: $black;
        text-decoration: none;
        font-size: 22px;
        font-weight: 500;

        &:hover {
          border-bottom: 2px solid rgba(56, 11, 39, 0.267);
        }
      }
    }
  }

  &__language {
    padding: 5px;

    &-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      &:hover .nav__language-dropdown {
        display: block;
      }
    }

    &-item {
      position: relative;
      list-style: none;
      width: 100%;
    }

    &-selector {
      color: $darkGrey;
      text-decoration: none;
      padding: 10px 20px;
      display: block;
      cursor: pointer;
      border: 3px solid #f53eb2cf;
      border-radius: 4px;
      font-weight: 400;
      font-size: 15px;
    }

    &-arrow {
      margin-left: 15px;
      font-size: 12px;
    }

    &-dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      background-color: $backgroundinput-color;
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
      z-index: 1;
      width: 100%;
      list-style: none;
      padding: 0;

      &-item {
        z-index: 1;

        a {
          display: flex;
          justify-content: center;
          align-items: center;
          color: $black;
          text-decoration: none;
          padding: 15px 0;
          list-style: none;
          border: 1px solid #f53eb2cf;
          font-size: 18px;

          img {
            margin-right: 8px;
            width: 20px;
            height: 20px;
          }

          &:hover {
            background-color: #f1f1f1;
          }
        }
      }
    }
  }
}

@media screen and (max-width: 778px) {
  .nav {
    &__logo {
      height: 120px;
      width: 120px;
      margin: 10px 0;
    }
  }
}

@media screen and (max-width: 998px) {
  .nav {
    display: grid;
    grid-template-columns: 30% 70%;

    &__menu {
      padding: 0;

      &-toggle {
        display: flex;
        position: absolute;
        right: 50px;
      }

      &-list {
        display: inline-block;
        width: 100%;
        height: 0;
        background: #fff;
        font-weight: 400;
        position: absolute;
        top: 13vh;
        left: -1px;
        box-shadow: 0 5px 30px -4px rgba(0, 0, 0, 0.2);
        transition: all 0.3s;
        padding: 0;

        &.showMenu {
          height: 800px;
        }

        &.showMenu li.nav__menu-item {
          height: 50px;
          opacity: 1;
          visibility: visible;
        }
      }

      &-item {
        width: 100%;
        height: 50px;
        float: left;
        opacity: 0;
        visibility: hidden;
        margin-left: 0;
        transition: all 0.3s 0.1s;
        border-top: 2px #bdc3c7 solid;
        text-align: center;
        padding-top: 20px;

        &:first-child {
          margin-top: 10px;
        }

        a {
          color: $black;
          font-size: 16px;
          letter-spacing: 2px;
        }
      }
    }
  }
}

@media screen and (min-width: 1200.1px) {
  li.nav__menu-item {
    margin-right: 50px;
    &:last-child {
      position: absolute;
      right: 5%;
    }
  }
}
 .email {
   height: 100%;
   padding: 15vh 0;
   margin: 0;
   display: flex;
   justify-content: center;
   align-items: center;


   &__confirmation {
     background-color: #f3f0f0;
     color: white;
     padding: 30px;
     width: 500px;
     border-radius: 8px;
     text-align: center;
     font-family: Arial, sans-serif;
     box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);

     &__content {
       display: flex;
       flex-direction: column;
       align-items: center;
     }

     &__icon {
       margin-bottom: 20px;

       img {
         width: 60px;
         height: auto;
       }
     }

     &__text {
       h2 {
         font-size: 24px;
         line-height: 1.4;
         margin-bottom: 15px;
         color: #1c1c1c;
       }

       p {
         font-size: 14px;
         color: #1c1c1c;

         .email-address {
           font-weight: bold;
           color: #1c1c1c;
         }
       }

       .email-resend {
         margin-top: 10px;

         a {
           color: rgb(89, 81, 201);
           text-decoration: none;

           &:hover {
             text-decoration: none;
           }
         }
       }
     }

     &__actions {
       display: flex;
       gap: 20px;
       margin-top: 30px;

       .email-confirmation__button {
         background-color: rgb(89, 81, 201);
         color: white;
         padding: 10px 20px;
         border-radius: 4px;
         text-decoration: none;
         font-weight: bold;

         &:hover {
           background-color: rgb(89, 81, 201);
         }
       }

       .email-confirmation__back {
         color: rgb(89, 81, 201);
         text-decoration: none;
         font-weight: 450;
         display: flex;
         align-items: center;
         &:hover {
           text-decoration: none;
         }
       }
     }
   }
 }
